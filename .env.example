# xyz-prompt — environment variables (optional)
# Copy to .env.local for local overrides. Never commit real secrets.

# VITE_APP_NAME=xyz-prompt

# Future build-time overrides (not used by default — API keys are stored in browser IndexedDB)
# VITE_DEFAULT_PROVIDER=
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=
# VITE_GOOGLE_API_KEY=
